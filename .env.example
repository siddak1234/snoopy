# Copy to .env.local and fill in. Never commit .env.local. Set in Vercel (or host) for production.
# Supabase: Dashboard → Connect for connection strings. Both URLs use SSL (sslmode=require).

# Runtime: transaction pooler (6543). Prisma CLI (migrate) auto-switches to port 5432 (session mode) so prepared statements work.
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1
POSTGRES_URL=

# Optional: direct (port 5432). Use only when running migrate from a context where direct is reachable; otherwise Prisma uses POSTGRES_URL.
# postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
POSTGRES_PRISMA_URL=

# Supabase Auth (OAuth + email/password). From Supabase Dashboard → Project Settings → API.
# Configure Google and Azure in Dashboard → Authentication → Providers. For Microsoft use tenant "common"; see docs/AUTH-MICROSOFT-AZURE.md.
# URL Configuration: Site URL and Redirect URLs MUST match the origin where users open the app
# (e.g. https://app.autom8x.com and https://app.autom8x.com/auth/callback; for dev use http://localhost:3000).
# If they differ (e.g. www vs non-www, or different port), the PKCE verifier cookie won't be sent and you'll see "PKCE code verifier not found".
# NEXT_PUBLIC_APP_URL is the canonical origin used for OAuth callbacks in production.
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional fallback key name used by some Supabase setups/libraries.
# If NEXT_PUBLIC_SUPABASE_ANON_KEY is set, that value is used first.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional: set to 1 to enable verbose OAuth/PKCE debug logs.
NEXT_PUBLIC_AUTH_DEBUG=
# Service role key (server-only). Required for account delete so we can remove the auth user and linked identities.
# Dashboard → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=

# GCS — server-only. Service account JSON (base64-encoded) + bucket name used by
# the invoice upload + signed-URL routes. The service account needs
# storage.objects.create + storage.objects.get on the bucket.
GCP_SERVICE_ACCOUNT_KEY_BASE64=
GCS_INVOICE_BUCKET=

# n8n invoice-ingest webhook (server-only). The Webhook trigger in n8n is set to
# Header Auth with header "X-Webhook-Secret"; the value below must match the
# credential configured on the n8n node. Generate with `openssl rand -hex 32`.
N8N_INGEST_WEBHOOK_URL=
N8N_INGEST_WEBHOOK_SECRET=
