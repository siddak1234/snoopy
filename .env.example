# Copy to .env.local and fill in. Never commit .env.local. Set in Vercel (or host) for production.
# Supabase: Dashboard → Connect for connection strings. Both URLs use SSL (sslmode=require).

# Runtime: transaction pooler (6543). Prisma CLI (migrate) auto-switches to port 5432 (session mode) so prepared statements work.
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1
POSTGRES_URL=

# Optional: direct (port 5432). Use only when running migrate from a context where direct is reachable; otherwise Prisma uses POSTGRES_URL.
# postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
POSTGRES_PRISMA_URL=

# Supabase Auth (OAuth + email/password). From Supabase Dashboard → Project Settings → API.
# Configure Google and Azure providers in Supabase Dashboard → Authentication → Providers.
# Add redirect URLs in Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: https://yourdomain.com (or http://localhost:3000 for local)
#   Redirect URLs: https://yourdomain.com/auth/callback, http://localhost:3000/auth/callback
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-only). Required for account delete so we can remove the auth user and linked identities.
# Dashboard → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=
